{
  "compilerOptions": {
    "target": "ES2021",
    "module": "NodeNext",
    "resolveJsonModule": true,
    "moduleResolution": "NodeNext",
    "isolatedModules": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "composite": false,
    "experimentalDecorators": true,
    "jsx": "react-jsx",
    "lib": [
      "dom",
      "es2021"
    ],
    "paths": {
      "@shared/*": [
        "../../packages/shared/src/*"
      ],
      "@nlux/core": [
        "../../packages/js/core/src"
      ],
      "@nlux/react": [
        "../../packages/react/core/src"
      ],
      "@nlux/nlbridge": [
        "../../packages/js/nlbridge/src"
      ]
    }
  }
}
